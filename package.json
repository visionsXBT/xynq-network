{
  "name": "xynq-network",
  "version": "0.4.2",
  "private": true,
  "description": "XYNQ — open AI inference served by a mesh of idle, community GPUs. Settled on Solana via $XYNQ.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n web,orch -c blue,green \"npm:dev\" \"npm:dev:server\"",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "start:server": "tsx server/index.ts",
    "start:keeper": "tsx scripts/keeper.ts",
    "seed": "tsx scripts/seed.ts",
    "backup": "tsx scripts/backup-db.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@mlc-ai/web-llm": "^0.2.79",
    "@privy-io/react-auth": "^2.4.1",
    "@pump-fun/pump-swap-sdk": "^1.5.0",
    "@solana/kit": "^2.1.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "better-sqlite3": "^11.7.0",
    "next": "^16.2.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
